#!/bin/bash
# .git/hooks/post-commit
#
# Fires after every commit on a feature branch.
# If the commit message matches the spec-approval pattern, launches the
# Agent SDK orchestrator (plan-auto.py) as an autonomous background process.
#
# Install:
#   cp .claude/hooks/post-commit .git/hooks/post-commit
#   chmod +x .git/hooks/post-commit

set -euo pipefail

COMMIT_MSG=$(git log -1 --pretty=%s)
BRANCH=$(git rev-parse --abbrev-ref HEAD)

# --- Guard: not on main ---
if [ "$BRANCH" = "main" ]; then
  exit 0
fi

# --- Spec approval: launch plan-auto ---
if echo "$COMMIT_MSG" | grep -qE '^chore\(spec\): approve spec for .+$'; then
  FEATURE=$(echo "$COMMIT_MSG" | sed 's/chore(spec): approve spec for //')

  if ! git show HEAD --name-only | grep -q "specs/$FEATURE/spec-approved"; then
    echo "[post-commit] spec approval commit detected but specs/$FEATURE/spec-approved not in commit. Skipping."
    exit 0
  fi

  ORCHESTRATOR=".claude/agents/plan-auto.py"
  if [ ! -f "$ORCHESTRATOR" ]; then
    echo "[post-commit] ERROR: $ORCHESTRATOR not found. Cannot trigger plan-auto."
    exit 1
  fi

  echo "[post-commit] Spec approved for $FEATURE. Launching plan-auto agent..."
  LOG_FILE="specs/$FEATURE/plan-auto.log"
  mkdir -p "specs/$FEATURE"
  nohup python "$ORCHESTRATOR" --feature "$FEATURE" > /dev/null 2>&1 &
  echo "[post-commit] plan-auto agent started (PID $!) — Log: $LOG_FILE"
  exit 0
fi

# --- Plan approval: launch tasks-auto ---
if echo "$COMMIT_MSG" | grep -qE '^chore\(plan\): approve plan for .+$'; then
  FEATURE=$(echo "$COMMIT_MSG" | sed 's/chore(plan): approve plan for //')

  if ! git show HEAD --name-only | grep -q "specs/$FEATURE/plan-approved"; then
    echo "[post-commit] plan approval commit detected but specs/$FEATURE/plan-approved not in commit. Skipping."
    exit 0
  fi

  ORCHESTRATOR=".claude/agents/tasks-auto.py"
  if [ ! -f "$ORCHESTRATOR" ]; then
    echo "[post-commit] ERROR: $ORCHESTRATOR not found. Cannot trigger tasks-auto."
    exit 1
  fi

  echo "[post-commit] Plan approved for $FEATURE. Launching tasks-auto agent..."
  LOG_FILE="specs/$FEATURE/tasks-auto.log"
  mkdir -p "specs/$FEATURE"
  nohup python "$ORCHESTRATOR" --feature "$FEATURE" > /dev/null 2>&1 &
  echo "[post-commit] tasks-auto agent started (PID $!) — Log: $LOG_FILE"
  exit 0
fi

# --- Tasks approval: launch test-auto ---
if echo "$COMMIT_MSG" | grep -qE '^chore\(tasks\): approve tasks for .+$'; then
  FEATURE=$(echo "$COMMIT_MSG" | sed 's/chore(tasks): approve tasks for //')

  if ! git show HEAD --name-only | grep -q "specs/$FEATURE/tasks-approved"; then
    echo "[post-commit] tasks approval commit detected but specs/$FEATURE/tasks-approved not in commit. Skipping."
    exit 0
  fi

  ORCHESTRATOR=".claude/agents/test-auto.py"
  if [ ! -f "$ORCHESTRATOR" ]; then
    echo "[post-commit] ERROR: $ORCHESTRATOR not found. Cannot trigger test-auto."
    exit 1
  fi

  echo "[post-commit] Tasks approved for $FEATURE. Launching test-auto agent..."
  LOG_FILE="specs/$FEATURE/test-auto.log"
  mkdir -p "specs/$FEATURE"
  nohup python "$ORCHESTRATOR" --feature "$FEATURE" > /dev/null 2>&1 &
  echo "[post-commit] test-auto agent started (PID $!) — Log: $LOG_FILE"
  exit 0
fi

# --- Test approval: launch implement-auto ---
if echo "$COMMIT_MSG" | grep -qE '^chore\(test\): approve tests for .+$'; then
  FEATURE=$(echo "$COMMIT_MSG" | sed 's/chore(test): approve tests for //')

  if ! git show HEAD --name-only | grep -q "specs/$FEATURE/test-approved"; then
    echo "[post-commit] test approval commit detected but specs/$FEATURE/test-approved not in commit. Skipping."
    exit 0
  fi

  ORCHESTRATOR=".claude/agents/implement-auto.py"
  if [ ! -f "$ORCHESTRATOR" ]; then
    echo "[post-commit] ERROR: $ORCHESTRATOR not found. Cannot trigger implement-auto."
    exit 1
  fi

  echo "[post-commit] Test approved for $FEATURE. Launching implement-auto agent..."
  LOG_FILE="specs/$FEATURE/implement-auto.log"
  mkdir -p "specs/$FEATURE"
  nohup python "$ORCHESTRATOR" --feature "$FEATURE" > /dev/null 2>&1 &
  echo "[post-commit] implement-auto agent started (PID $!) — Log: $LOG_FILE"
  exit 0
fi

exit 0
